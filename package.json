{
  "name": "eml",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --react-plugin --deny-warnings src packages/emlib/src packages/emlib/test build.ts",
    "lint:fix": "oxlint --react-plugin --fix src packages/emlib/src packages/emlib/test build.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit && (cd packages/emlib && bun run build)",
    "check": "bun lint && bun typecheck && bun test && bun run build"
  },
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "bun-plugin-tailwind": "^0.1.2",
    "clsx": "^2.1.1",
    "emlib": "workspace:*",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.63.0",
    "tailwindcss": "^4.2.4"
  }
}
